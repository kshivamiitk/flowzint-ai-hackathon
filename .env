APP_ENV=development
DEMO_MODE=true

DATABASE_URL=sqlite+aiosqlite:///./pulseresolve.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

AI_PROVIDER=local
EMBEDDING_MODEL=local

AUTO_REFUND_LIMIT=500
