APP_ENV=development
DEMO_MODE=true

DATABASE_URL=sqlite+aiosqlite:///./pulseresolve.db
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Free default: uses the deterministic built-in chatbot and local embeddings.
# No API key is required in this mode.
AI_PROVIDER=local
EMBEDDING_MODEL=local

# Optional hosted chatbot APIs.
# Use one provider block at a time. Keep EMBEDDING_MODEL=local for free chat
# APIs that do not expose a compatible embeddings endpoint.

# Groq: create a free API key at https://console.groq.com/keys
# AI_PROVIDER=openai_compatible
# CHATBOT_API_BASE_URL=https://api.groq.com/openai/v1
# CHATBOT_API_KEY=your_groq_api_key_here
# CHATBOT_MODEL=llama-3.1-8b-instant
# EMBEDDING_MODEL=local

# Google Gemini: create a free key in Google AI Studio.
# AI_PROVIDER=openai_compatible
# CHATBOT_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# CHATBOT_API_KEY=your_gemini_api_key_here
# CHATBOT_MODEL=gemini-3.5-flash
# EMBEDDING_MODEL=local

# OpenRouter: create a key at https://openrouter.ai/keys and use free models.
# AI_PROVIDER=openai_compatible
# CHATBOT_API_BASE_URL=https://openrouter.ai/api/v1
# CHATBOT_API_KEY=your_openrouter_api_key_here
# CHATBOT_MODEL=openrouter/free
# EMBEDDING_MODEL=local

# Optional local Ollama-compatible chatbot API. No key is required.
# Start Ollama separately, then use an installed chat model.
# AI_PROVIDER=openai_compatible
# CHATBOT_API_BASE_URL=http://localhost:11434/v1
# CHATBOT_API_KEY=
# CHATBOT_MODEL=llama3
# EMBEDDING_MODEL=local

AUTO_REFUND_LIMIT=500
APPROVAL_REFUND_LIMIT=2000
INCIDENT_SIMILARITY_THRESHOLD=0.68
INCIDENT_MIN_COMPLAINTS=3
INCIDENT_WINDOW_MINUTES=60

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
